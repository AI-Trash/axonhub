{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 140,
  "tabWidth": 2,
  "semi": true,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "bracketSpacing": true,
  "endOfLine": "lf",
  "trailingComma": "es5",
  "sortImports": {},
  "sortTailwindcss": {
    "functions": ["cn", "clsx", "cva"]
  },
  "ignorePatterns": ["dist", "src/routeTree.gen.ts"]
}
